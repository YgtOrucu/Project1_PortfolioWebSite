@model List<Service>
@{
    ViewData["Title"] = "Services";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="flex h-screen overflow-hidden">
    <main class="flex-1 flex flex-col overflow-hidden">
        <section class="flex-1 overflow-y-auto p-8 custom-scrollbar bg-slate-50 dark:bg-[#0c0710]">
            <div class="flex flex-wrap items-end justify-between gap-6 mb-10">
                <div class="max-w-2xl">
                    <h2 class="text-slate-900 dark:text-white text-4xl font-extrabold tracking-tight mb-2">Servisler</h2>
                    <p class="text-slate-500 dark:text-[#ab9db9] text-base leading-relaxed">Müşterilerinizle etkileşim kurabileceğiniz web sitenizde görüntülenen temel iş tekliflerini yapılandırın.</p>
                </div>
                <a href="/Admin/ServicesAdd" class="flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-xl font-bold transition-all shadow-xl shadow-primary/20 group">
                    <span class="material-symbols-outlined group-hover:rotate-90 transition-transform">add</span>
                    <span>Ekle</span>
                </a>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                @foreach (var item in Model)
                {
                    <div class="group relative bg-white dark:bg-card-dark border border-slate-200 dark:border-border-dark rounded-xl p-6 transition-all hover:shadow-2xl hover:shadow-primary/5 hover:-translate-y-1">
                        <div class="flex justify-between items-start mb-4">
                            <div class="h-14 w-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary">
                                <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1">code</span>
                            </div>
                            <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a href="/Admin/ServicesEdit/@(item.ServiceId)" class="p-2 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Edit Service">
                                    <span class="material-symbols-outlined text-xl">edit</span>
                                </a>
                                <a href="/Admin/ServicesDelete/@(item.ServiceId)" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-500/10 rounded-lg transition-all" title="Delete Service">
                                    <span class="material-symbols-outlined text-xl">delete</span>
                                </a>
                            </div>
                        </div>
                        <h3 class="text-slate-900 dark:text-white text-xl font-bold mb-2">@(item.Title)</h3>
                        <p class="text-slate-500 dark:text-[#ab9db9] text-sm leading-relaxed line-clamp-3">@(item.Description)</p>
                        <div class="mt-6 flex items-center gap-2 text-xs font-semibold text-primary uppercase tracking-wider">
                            <span>Icon Url</span>
                            <span class="w-1 h-1 bg-primary rounded-full"></span>
                            <span class="text-slate-400">@(item.IconUrl)</span>
                        </div>
                    </div>
                }
            </div>
        </section>
    </main>
</div>