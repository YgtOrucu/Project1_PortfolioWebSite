@model List<Category>
@{
    ViewData["Title"] = "Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Main Content Area -->
<main class="flex-1 overflow-y-auto bg-slate-50 dark:bg-background-dark/50">
    <div class="max-w-6xl mx-auto p-8">
        <!-- Page Heading -->
        <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
            <div class="flex flex-col gap-1">
                <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Kategoriler</h1>
                <p class="text-slate-500 dark:text-[#ad9db9]">Kategori ana sayfası için yeni kategori ekleyebilir ve güncelleyebilirsiniz.</p>
            </div>
            <a href="/Admin/CategoryAdd" class="flex items-center gap-2 px-6 h-11 bg-primary hover:bg-primary/90 text-white rounded-lg font-bold shadow-lg shadow-primary/20 transition-all transform active:scale-95">
                <span class="material-symbols-outlined">add_circle</span>
                <span>Ekle</span>
            </a>
        </div>
        <!-- Table Section -->
        <div class="bg-white dark:bg-[#151118] border border-slate-200 dark:border-[#322839] rounded-xl overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-[#221c27] border-b border-slate-200 dark:border-[#322839]">
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-[#ad9db9]">Kategori İsmin</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-[#ad9db9]">Data Filter</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-[#ad9db9] text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-[#322839]">
                        @foreach (var item in Model)
                        {
                            <tr class="group hover:bg-slate-50 dark:hover:bg-[#1e1924] transition-colors">
                                <td class="px-6 py-5">
                                    <div class="flex items-center gap-3">
                                        <div class="size-2 rounded-full bg-primary"></div>
                                        <span class="font-medium text-slate-900 dark:text-white">@(item.Name)</span>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <span class="font-mono text-xs px-2.5 py-1 rounded bg-slate-100 dark:bg-[#322839] text-slate-600 dark:text-primary font-semibold border border-slate-200 dark:border-primary/20">@(item.DataFilter)</span>
                                </td>
                                <td class="px-6 py-5 text-right">
                                    <div class="flex justify-end gap-2">
                                        <a href="/Admin/CategoryEdit/@(item.CategoryId)" class="p-2 text-slate-400 hover:text-primary dark:text-[#ad9db9] dark:hover:text-white transition-colors">
                                            <span class="material-symbols-outlined text-xl">edit_note</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>

                        }
                    </tbody>
                </table>
            </div>
            <div class="p-4 bg-slate-50/50 dark:bg-[#221c27]/30 border-t border-slate-100 dark:border-[#322839] flex items-center justify-between">
                <span class="text-xs text-slate-500 dark:text-[#ad9db9]">Toplam @Model.Count adet kategori bulumaktadır</span>
            </div>
        </div>
    </div>
</main>

