@model List<About>
@{
    ViewData["Title"] = "About";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-8 max-w-5xl mx-auto w-full">
    <!-- Page Heading -->
    <div class="flex flex-wrap justify-between items-end gap-4 mb-8">
        <div class="flex flex-col gap-2">
            <h2 class="text-4xl font-black leading-tight tracking-tight">Hakkında</h2>
            <p class="text-[#ad9db9] text-base font-normal">
                Portföy ana sayfası için profesyonel profil özetlerini düzenleyin ve güncelleyin.
            </p>

        </div>
        <a href="/Admin/AboutAdd" class="flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-lg transition-all font-bold shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined">add</span>
            <span>Ekle</span>
        </a>
    </div>
    <!-- Grid of Cards -->
    <div class="grid grid-cols-1 gap-6">
        @foreach (var item in Model)
        {
            <div class="glass-card rounded-xl p-6 flex flex-col md:flex-row gap-6 items-start md:items-center hover:border-primary/40 transition-all duration-300">
                <div class="size-24 rounded-xl bg-cover bg-center shrink-0 shadow-xl border border-white/10" data-alt="Developer profile photo in professional setting" style="background-image: url('@(item.ImageUrl)')"></div>
                <div class="flex-1 space-y-2">
                    <h3 class="text-xl font-bold">@(item.NameSurname)</h3>
                    <p class="text-primary text-sm font-semibold">@(item.Title)</p>
                    <p class="text-[#ad9db9] text-sm leading-relaxed line-clamp-2">
                        @(item.Description)
                    </p>
                </div>
                <div class="flex flex-row md:flex-col gap-2 w-full md:w-auto">
                    <a href="/Admin/AboutEdit/@(item.AboutId)" class="flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-slate-100 dark:bg-[#322839] hover:bg-primary hover:text-white rounded-lg transition-all text-sm font-bold">
                        <span class="material-symbols-outlined text-lg">edit</span>
                        Düzenle
                    </a>
                    <a href="/Admin/AboutDelete/@(item.AboutId)" class="flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-slate-100 dark:bg-[#322839] hover:bg-red-500 hover:text-white rounded-lg transition-all text-sm font-bold">
                        <span class="material-symbols-outlined text-lg">delete</span>
                       Sil
                    </a>
                </div>
            </div>
        }
    </div>
</div>
