@model List<Portfolio>
@{
    ViewData["Title"] = "Portfolio";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="flex min-h-screen">
    <!-- Main Content -->
    <main class="flex-1 flex flex-col">
        <div class="p-8 max-w-7xl mx-auto w-full space-y-8">
            <!-- Page Heading -->
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div class="space-y-1">
                    <h2 class="text-3xl font-extrabold tracking-tight dark:text-white">Projelerim</h2>
                    <p class="text-slate-500 dark:text-slate-400">Ana Sayfa için projelerinizi yönetebilir, ekleme ve güncelleme işlemlerinizi yapabilirsiniz.</p>
                </div>
                <a href="/Admin/PortfolioAdd" class="bg-primary hover:bg-primary/90 text-white font-bold py-2.5 px-6 rounded-lg flex items-center gap-2 transition-all shadow-lg shadow-primary/20">
                    <span class="material-symbols-outlined">add</span>
                    Ekle
                </a>
            </div>
            <div>
                <div class="xl:col-span-2 space-y-6">
                    <div class="bg-white dark:bg-card-dark rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-widest font-bold">
                                        <th class="px-6 py-4">Resim</th>
                                        <th class="px-6 py-4">Başlık</th>
                                        <th class="px-6 py-4">Kategori</th>
                                        <th class="px-6 py-4 text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                                    @foreach (var item in Model)
                                    {
                                        <tr class="group hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                                            <td class="px-6 py-4">
                                                <div class="size-12 rounded-lg bg-slate-200 dark:bg-slate-700 bg-cover bg-center shadow-sm"
                                                     data-alt="Modern interior villa design" style="background-image: url('@(item.ImageUrl)')"></div>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="font-bold text-slate-900 dark:text-slate-100">@(item.Title)</div>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-bold uppercase rounded-full">@(item.Category.Name)</span>
                                            </td>
                                            <td class="px-6 py-4 text-right">
                                                <div class="flex items-center justify-end gap-2">
                                                    <a href="/Admin/PortfolioEdit/@(item.PortfolioId)" class="p-2 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Edit">
                                                        <span class="material-symbols-outlined text-xl">edit</span>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="p-4 bg-slate-50 dark:bg-slate-800/20 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
                            <span class="text-xs text-slate-500">Toplam @Model.Count adet Proje bulunmaktasır.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>