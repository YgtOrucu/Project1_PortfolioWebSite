@model Education
@{
    ViewData["Title"] = "EducationEdit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-background-dark/80 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-xl glass-modal rounded-2xl overflow-hidden shadow-2xl border border-white/5">
        <div class="p-8">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-2xl font-bold text-white tracking-tight">Eğitim Güncelle</h2>
                    <p class="text-slate-400 text-sm mt-1">Aşağıda akademik bilgilerinizi güncelleyebilirsiniz.</p>
                </div>
            </div>
            <form asp-action="EducationUpdate" asp-controller="Admin" class="space-y-6" method="post">
                <input asp-for="EducationId" type="hidden" />
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-300" for="Title">Başlık</label>
                    <input class="w-full bg-background-dark/50 border border-border-dark focus:border-primary focus:ring-1 focus:ring-primary rounded-xl px-4 py-3 text-white placeholder:text-slate-600 outline-none transition-all" asp-for="Title" placeholder="e.g. B.Sc. Computer Science" type="text" />
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-300" for="SchoolName">Okul Adı</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-500">school</span>
                        <input class="w-full bg-background-dark/50 border border-border-dark focus:border-primary focus:ring-1 focus:ring-primary rounded-xl pl-12 pr-4 py-3 text-white placeholder:text-slate-600 outline-none transition-all" asp-for="SchoolName" placeholder="e.g. Harvard University" type="text" />
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-300" for="Date">Tarih</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-500">calendar_month</span>
                        <input class="w-full bg-background-dark/50 border border-border-dark focus:border-primary focus:ring-1 focus:ring-primary rounded-xl pl-12 pr-4 py-3 text-white placeholder:text-slate-600 outline-none transition-all" asp-for="Date" placeholder="e.g. 2020 - 2024" type="text" />
                    </div>
                </div>
                <div class="flex items-center justify-end gap-4 pt-4">
                    <a href="/Admin/Education" class="px-6 py-2.5 rounded-xl border border-border-dark text-slate-300 font-semibold hover:bg-white/5 transition-colors" type="button">
                        Geri
                    </a>
                    <button class="px-8 py-2.5 rounded-xl bg-primary hover:bg-primary/90 text-white font-bold transition-all shadow-lg shadow-primary/30" type="submit">
                        Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

