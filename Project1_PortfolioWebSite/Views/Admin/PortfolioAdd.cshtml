@model Portfolio
@{
    ViewData["Title"] = "PortfolioAdd";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-background-dark/80 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-xl glass-modal rounded-2xl overflow-hidden shadow-2xl border border-white/5">
        <div class="p-8">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-2xl font-bold text-white tracking-tight">Proje Ekle</h2>
                    <p class="text-slate-400 text-sm mt-1">Aşağıya proje bilgilerinizi girin.</p>
                </div>
            </div>
            <form class="space-y-6" method="post">
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-300" for="Title">Başlık</label>
                    <input class="w-full bg-background-dark/50 border border-border-dark focus:border-primary focus:ring-1 focus:ring-primary rounded-xl px-4 py-3 text-white placeholder:text-slate-600 outline-none transition-all" id="Title" name="Title" placeholder="e.g. E-Ticaret Web Sitesi " type="text" />
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-300" for="SchoolName">Resim Url</label>
                    <div class="relative">
                        <input class="w-full bg-background-dark/50 border border-border-dark focus:border-primary focus:ring-1 focus:ring-primary rounded-xl pr-4 py-3 text-white placeholder:text-slate-600 outline-none transition-all" id="ImageUrl" name="ImageUrl" placeholder="e.g. https://....." type="text" />
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-300" for="Date">Category</label>
                    <div class="relative">
                        @Html.DropDownListFor(x => x.CategoryId, (IEnumerable<SelectListItem>)ViewBag.categories, new { @class = "w-full bg-background-dark/50 border border-border-dark focus:border-primary focus:ring-1 focus:ring-primary rounded-xl pr-4 py-3 text-white placeholder:text-slate-600 outline-none transition-all" })
                    </div>
                </div>
                <div class="flex items-center justify-end gap-4 pt-4">
                    <a href="/Admin/Portfolio" class="px-6 py-2.5 rounded-xl border border-border-dark text-slate-300 font-semibold hover:bg-white/5 transition-colors" type="button">
                        Geri
                    </a>
                    <button class="px-8 py-2.5 rounded-xl bg-primary hover:bg-primary/90 text-white font-bold transition-all shadow-lg shadow-primary/30" type="submit">
                        Ekle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

